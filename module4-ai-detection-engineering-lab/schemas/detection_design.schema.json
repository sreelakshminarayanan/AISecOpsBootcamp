{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["objective", "behavior", "data_source", "required_fields", "suspicious_values", "selection_logic", "exclusions", "attack_mapping", "assumptions", "known_gaps", "positive_tests", "negative_tests", "tuning_hypotheses"],
  "properties": {
    "objective": {"type": "string", "minLength": 10},
    "behavior": {"type": "string", "minLength": 10},
    "data_source": {"type": "string", "minLength": 3},
    "required_fields": {"type": "array", "minItems": 2, "items": {"type": "string"}},
    "suspicious_values": {"type": "array", "minItems": 1},
    "selection_logic": {"type": "array", "minItems": 1},
    "exclusions": {"type": "array"},
    "attack_mapping": {"type": "array", "minItems": 1},
    "assumptions": {"type": "array"},
    "known_gaps": {"type": "array"},
    "positive_tests": {"type": "array", "minItems": 2},
    "negative_tests": {"type": "array", "minItems": 3},
    "tuning_hypotheses": {"type": "array"}
  },
  "additionalProperties": true
}
